<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{% if title %}{{ title }} | {% endif %}LC Education Consulting</title>
<meta name="description" content="{% if description %}{{ description }}{% else %}Accessibility reviews, training, and digital accessibility support rooted in 16 years of special education experience.{% endif %}" />
<meta name="keywords" content="digital accessibility consulting, WCAG compliance, web accessibility audit, VPAT writing, PDF remediation, assistive technology, ADA Title II, screen reader testing, accessibility training, special education consulting, New Jersey accessibility consultant" />
<meta name="author" content="LC Education Consulting" />
<link rel="canonical" href="{{ site.url }}{{ page.url }}" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="LC Education Consulting" />
<meta property="og:title" content="{% if title %}{{ title }} | LC Education Consulting{% else %}LC Education Consulting{% endif %}" />
<meta property="og:description" content="{% if description %}{{ description }}{% else %}Accessibility reviews, training, and digital accessibility support rooted in 16 years of special education experience.{% endif %}" />
<meta property="og:url" content="{{ site.url }}{{ page.url }}" />
<meta property="og:image" content="{{ site.url }}/img/lc-logo.svg" />
<meta property="og:image:alt" content="LC Education Consulting logo" />
<meta property="og:locale" content="en_US" />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content="{% if title %}{{ title }} | LC Education Consulting{% else %}LC Education Consulting{% endif %}" />
<meta name="twitter:description" content="{% if description %}{{ description }}{% else %}Accessibility reviews, training, and digital accessibility support rooted in 16 years of special education experience.{% endif %}" />
<meta name="twitter:image" content="{{ site.url }}/img/lc-logo.svg" />
<meta name="twitter:image:alt" content="LC Education Consulting logo" />

<!-- JSON-LD: Business schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "{{ site.name }}",
  "url": "{{ site.url }}",
  "telephone": "{{ site.phone }}",
  "email": "{{ site.email }}",
  "description": "Accessibility reviews, training, and digital accessibility support rooted in 16 years of special education experience.",
  "foundingDate": "{{ site.foundingDate }}",
  "founder": {
    "@type": "Person",
    "name": "{{ site.founder }}"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "{{ site.city }}",
    "addressRegion": "{{ site.state }}",
    "addressCountry": "{{ site.country }}"
  },
  "areaServed": "US",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Accessibility Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Digital Accessibility Audits" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "VPAT Writing" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "PDF and Document Remediation" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Remediation Roadmaps" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Accessibility Training and Webinars" } }
    ]
  }
}
</script>

<link rel="manifest" href="{{ '/manifest.webmanifest' | url }}" />
<link rel="icon" type="image/svg+xml" href="{{ '/img/favicon.svg' | url }}" />
<link rel="apple-touch-icon" sizes="180x180" href="{{ '/img/lc-logo.svg' | url }}" />
<meta name="theme-color" content="#556b2f" />
<link rel="preload" href="{{ '/fonts/lato-400.woff2' | url }}" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="{{ '/fonts/lato-700.woff2' | url }}" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="{{ '/css/main.css' | url }}" as="style" />
<link rel="stylesheet" href="{{ '/css/main.css' | url }}" />
<!-- Umami Analytics — replace YOUR_WEBSITE_ID with your site's ID from the Umami dashboard -->
<script defer src="https://cloud.umami.is/script.js" data-website-id="YOUR_WEBSITE_ID"></script>
