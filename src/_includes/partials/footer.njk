<footer class="site-footer">
  <div class="container">
    <div class="footer-inner">
      <nav class="footer-nav">
        <ul class="footer-nav__list">
          {% for link in navigation.links %}
            {% if not link.hideFromFooter %}
              {% if link.dropdown %}
                {% for child in link.children %}
                <li class="footer-nav__item">
                  <a href="{{ child.url | url }}" class="footer-nav__link">{{ child.text }}</a>
                </li>
                {% endfor %}
              {% elif link.external %}
              <li class="footer-nav__item">
                <a href="{{ link.url }}" class="footer-nav__link" target="_blank" rel="noopener noreferrer">{{ link.text }}</a>
              </li>
              {% else %}
              <li class="footer-nav__item">
                <a href="{{ link.url | url }}" class="footer-nav__link">{{ link.text }}</a>
              </li>
              {% endif %}
            {% endif %}
          {% endfor %}
        </ul>
      </nav>
      <hr class="divider">
      <p class="footer-brand"><a href="{{ '/' | url }}">LC Education Consulting</a></p>
      <p class="footer-phone"><a href="tel:3027507443">302-750-7443</a></p>
      <p class="footer-copy text-uppercase">Copyright &copy; 2026 LC Education Consulting &mdash; All Rights Reserved.</p>
    </div>
  </div>
</footer>
