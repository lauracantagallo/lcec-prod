<section class="section section--blue">
  <div class="container">
    <div class="cta-block">
      <h2 class="cta-block__heading">{{ cta.heading }}</h2>
      <p class="cta-block__subheading">{{ cta.subheading }}</p>
      <a href="{{ cta.button_url or site.calendar_url }}" class="btn btn--ghost" target="_blank" rel="noopener noreferrer">{{ cta.button_text }}</a>
    </div>
  </div>
</section>
