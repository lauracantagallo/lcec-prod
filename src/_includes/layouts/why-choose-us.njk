---
layout: base.njk
---
<section class="section section--white section--flush-top section--flush-bottom">
  <div class="container">
    <h1 class="heading--section">{{ page_title.heading }}</h1>
    <div class="bio-layout">
      <img src="{{ '/img/laura-cantagallo.webp' | url }}" alt="Laura Cantagallo, founder of LC Education Consulting" class="bio-layout__photo" width="400" height="400" />
      <div class="bio-layout__text">
        <h2 class="bio-layout__subheading">{{ page_title.subheading }}</h2>
        {% for paragraph in body %}
        <p class="bio-layout__body">{{ paragraph }}</p>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<div class="container">
  <hr class="divider" />
</div>

<section class="section section--white section--flush-top section--flush-bottom">
  <div class="container">
    <div class="credentials-layout">
      <div class="credentials-layout__text">
        <h2 class="bio-layout__subheading">{{ credentials_heading }}</h2>
        <ul class="credentials-list">
          {% for item in credentials %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
      </div>
      <img src="{{ '/img/why-choose-us_career.webp' | url }}" alt="" class="credentials-layout__photo" aria-hidden="true" loading="lazy" />
    </div>
  </div>
</section>

<section class="section section--white section--flush-bottom">
  <div class="container">
    <h2 class="content-blocks__heading">What Clients Have to Say</h2>
    <div class="content-blocks__block why-quote">
      <p class="why-quote__text">{{ quote.text }}</p>
      <p class="why-quote__attribution">&mdash; {{ quote.attribution }}</p>
    </div>
  </div>
</section>

{% include "partials/social-section.njk" %}
