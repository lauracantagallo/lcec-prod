---
layout: base.njk
---
<section class="section section--blue">
  <div class="container">
    <div class="portfolio-intro">
      <h1 class="portfolio-intro__heading">{{ page_title.heading }}</h1>
      <p>{{ intro_body }}</p>
    </div>
  </div>
</section>

<section class="section section--white">
  <div class="container">
    <h2 class="philosophy-section__heading">{{ projects_heading }}</h2>
    <div class="philosophy-section__grid">
      {% for project in projects %}
      <article class="philosophy-section__block">
        {% if project.image %}
        <img src="{{ project.image | url }}" alt="" class="philosophy-section__image" aria-hidden="true" loading="lazy" />
        {% endif %}
        <p>{{ project.title }}</p>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section--blue">
  <div class="container">
    <div class="cta-block">
      <h2 class="cta-block__heading">{{ cta.heading }}</h2>
      <p class="cta-block__subheading">{{ cta.subheading }}</p>
      <a href="{{ cta.button_url }}" class="btn btn--ghost" target="_blank" rel="noopener">{{ cta.button_text }}</a>
    </div>
  </div>
</section>
