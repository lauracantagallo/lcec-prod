---
layout: base.njk
---
<section class="section section--blue">
  <div class="container">
    <div class="page-intro">
      <h1 class="page-intro__heading">{{ page_title.heading }}</h1>
      <p>{{ intro_body }}</p>
      <a href="{{ '/contact/' | url }}" class="btn btn--ghost">Contact Us</a>
    </div>
  </div>
</section>

<section class="section section--white section--flush-bottom">
  <div class="container">
    <h2 class="content-blocks__heading">{{ projects_heading }}</h2>
    <div class="content-blocks__grid">
      {% for project in projects %}
      <article class="content-blocks__block">
        {% if project.image %}
        <img src="{{ project.image | url }}" alt="" class="content-blocks__image" aria-hidden="true" loading="lazy" />
        {% endif %}
        <p>{{ project.title }}</p>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

{% include "partials/social-section.njk" %}

{% include "partials/cta.njk" %}
